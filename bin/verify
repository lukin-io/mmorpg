#!/usr/bin/env bash
# frozen_string_literal: true
#
# Pre-push verification script
# Run this before pushing to catch CI failures locally
#
# Usage:
#   bin/verify          # Full verification
#   bin/verify quick    # Quick check (lint + model specs only)
#   bin/verify lint     # Linting only
#   bin/verify combat   # Combat subsystem tests
#

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo_step() {
  echo -e "\n${YELLOW}▶ $1${NC}"
}

echo_info() {
  echo -e "${BLUE}ℹ $1${NC}"
}

echo_success() {
  echo -e "${GREEN}✓ $1${NC}"
}

echo_error() {
  echo -e "${RED}✗ $1${NC}"
}

run_lint() {
  echo_step "Running StandardRB linter..."
  if bundle exec standardrb --fix; then
    echo_success "StandardRB passed"
  else
    echo_error "StandardRB failed - fix issues before pushing"
    exit 1
  fi

  echo_step "Running Rubocop auto-fix..."
  if bundle exec rubocop -a --format simple 2>/dev/null; then
    echo_success "Rubocop passed"
  else
    echo_error "Rubocop failed - fix issues before pushing"
    exit 1
  fi
}

run_factories() {
  echo_step "Validating factories via model specs..."
  # Model specs exercise factories heavily - catches attribute/schema issues
  if bundle exec rspec spec/models --format progress --fail-fast 2>/dev/null; then
    echo_success "Model specs passed (factories valid)"
  else
    echo_error "Model specs failed - check factories and schema"
    exit 1
  fi
}

run_tests() {
  echo_step "Running full test suite..."
  if bundle exec rspec --format progress; then
    echo_success "All tests passed"
  else
    echo_error "Tests failed"
    exit 1
  fi
}

run_combat_tests() {
  echo_step "Running combat subsystem tests..."
  if bundle exec rspec spec/services/game/combat/ spec/lib/game/ --format progress; then
    echo_success "Combat tests passed"
  else
    echo_error "Combat tests failed"
    exit 1
  fi
}

case "${1:-full}" in
  lint)
    run_lint
    ;;
  quick)
    run_lint
    run_factories
    echo_success "Quick verification complete!"
    ;;
  combat)
    run_lint
    run_combat_tests
    ;;
  full|*)
    run_lint
    run_factories
    run_tests

    echo -e "\n${GREEN}═══════════════════════════════════════${NC}"
    echo -e "${GREEN}  ✓ All checks passed - safe to push!  ${NC}"
    echo -e "${GREEN}═══════════════════════════════════════${NC}"
    ;;
esac
