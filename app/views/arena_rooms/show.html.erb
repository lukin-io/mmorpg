<% content_for :title, "#{@room.name} - Arena" %>

<%
  active_tab = (params[:ft].presence || "1").to_s
  tab_fight_type = {"1" => "duel", "2" => "team_battle", "3" => "sacrifice"}[active_tab] || "duel"
  visible_applications = @applications.select { |app| app.fight_type == tab_fight_type }
%>

<div class="nl-arena-frame"
     data-controller="arena"
     data-arena-room-id-value="<%= @room.id %>"
     data-arena-character-id-value="<%= current_character.id %>"
     data-arena-character-level-value="<%= current_character.level %>">
  <div class="nl-arena-topline">
    <div class="nl-arena-character">
      <%= current_character.name %>[<%= current_character.level %>]
      <span class="nl-arena-vitals"><%= current_character.current_hp %>/<%= current_character.max_hp %> | <%= current_character.current_mp %>/<%= current_character.max_mp %></span>
    </div>
    <div class="nl-arena-controls">
      <%= link_to "Ваш персонаж", profile_path(profile_name: current_character.name), class: "nl-arena-link" %>
      <%= link_to "Инвентарь", inventory_path, class: "nl-arena-link" %>
      <%= link_to "Арена", arena_index_path, class: "nl-arena-link" %>
      <%= link_to "В город", world_path, class: "nl-arena-link" %>
    </div>
  </div>

  <div class="nl-arena-room-heading">
    <b><%= @room.name %></b>
    <span>уровни <%= @room.level_min %>-<%= @room.level_max %></span>
    <% if @room.faction_restriction.present? %>
      <span><%= @room.faction_restriction.humanize %></span>
    <% end %>
  </div>

  <div class="nl-arena-status-row">
    <span>Фильтр заявок: <%= link_to "Ваш уровень", arena_room_path(@room, ft: active_tab, level: current_character.level), class: "nl-arena-filter" %> | <%= link_to "Все", arena_room_path(@room, ft: active_tab), class: "nl-arena-filter" %></span>
    <span>Количество заявок: <b><%= visible_applications.size %></b></span>
    <%= link_to "Обновить", arena_room_path(@room, ft: active_tab), class: "nl-arena-link" %>
    <%= link_to "Показать схему здания", arena_index_path, class: "nl-arena-link" %>
  </div>

  <div class="nl-arena-tabs">
    <%= link_to "Дуэли", arena_room_path(@room, ft: 1), class: "nl-arena-tab #{'nl-arena-tab--active' if active_tab == '1'}" %>
    <%= link_to "Групповые", arena_room_path(@room, ft: 2), class: "nl-arena-tab #{'nl-arena-tab--active' if active_tab == '2'}" %>
    <%= link_to "Жертвенные", arena_room_path(@room, ft: 3), class: "nl-arena-tab #{'nl-arena-tab--active' if active_tab == '3'}" %>
    <span class="nl-arena-tab nl-arena-tab--disabled">Тактические</span>
    <span class="nl-arena-tab nl-arena-tab--disabled">Тотализатор</span>
    <%= link_to "Статистика", arena_index_path(ft: 4), class: "nl-arena-tab" %>
  </div>

  <div class="nl-arena-application-form" data-arena-target="formContainer">
    <% if @my_application %>
      <div class="nl-arena-current-row">
        <b>Ваша заявка:</b>
        <%= fight_type_label(@my_application.fight_type) %>,
        <%= fight_kind_label(@my_application.fight_kind) %>,
        таймаут <%= @my_application.timeout_seconds / 60 %> мин,
        травматичность <%= @my_application.trauma_percent %>%.
        <%= button_to "отозвать Вашу заявку на участие в поединке",
            arena_room_arena_application_path(@room, @my_application),
            method: :delete,
            class: "nl-arena-small-button" %>
      </div>
    <% else %>
      <%= form_with url: arena_room_arena_applications_path(@room),
                    method: :post,
                    class: "nl-arena-inline-form",
                    data: { action: "submit->arena#submitApplication" } do |f| %>
        <%= f.hidden_field :fight_type, value: tab_fight_type %>
        <%= f.select :fight_kind,
            [["тип боя", ""], ["Без вооружения", "no_weapons"], ["Без артефактов", "no_artifacts"], ["Ограниченные артефакты", "limited_artifacts"], ["Произвольный", "free"], ["Клан на клан", "clan_vs_clan"], ["Склонность на склонность", "faction_vs_faction"], ["Закрытый бой", "closed"]],
            {},
            class: "nl-arena-select",
            required: true %>
        <%= f.select :timeout_seconds,
            [["таймаут", ""], ["2 мин", 120], ["3 мин", 180], ["4 мин", 240], ["5 мин", 300]],
            {},
            class: "nl-arena-select",
            required: true %>
        <%= f.select :trauma_percent,
            [["% травматичности", ""], ["легкая (10%)", 10], ["средняя (30%)", 30], ["тяжелая (50%)", 50], ["оч. тяжелая (80%)", 80]],
            {},
            class: "nl-arena-select",
            required: true %>

        <% if active_tab != "1" %>
          <%= f.select :wait_minutes,
              [["ожидание", ""], ["5 мин", 5], ["10 мин", 10], ["15 мин", 15], ["30 мин", 30], ["45 мин", 45], ["60 мин", 60]],
              {},
              class: "nl-arena-select",
              required: true %>
          <span class="nl-arena-team-limits">
            своя группа:
            <%= f.number_field :team_count, min: 1, max: 10, value: 1, class: "nl-arena-mini-input" %>
            уровни
            <%= f.number_field :team_level_min, min: 0, max: 33, value: [current_character.level - 1, 0].max, class: "nl-arena-mini-input" %>
            -
            <%= f.number_field :team_level_max, min: 0, max: 33, value: current_character.level + 1, class: "nl-arena-mini-input" %>
            против:
            <%= f.number_field :enemy_count, min: 1, max: 10, value: 1, class: "nl-arena-mini-input" %>
            уровни
            <%= f.number_field :enemy_level_min, min: 0, max: 33, value: [current_character.level - 1, 0].max, class: "nl-arena-mini-input" %>
            -
            <%= f.number_field :enemy_level_max, min: 0, max: 33, value: current_character.level + 1, class: "nl-arena-mini-input" %>
          </span>
        <% end %>

        <%= f.submit "подать заявку", class: "nl-arena-small-button" %>
      <% end %>
    <% end %>
  </div>

  <table class="nl-arena-table nl-arena-applications-table" data-arena-target="applicationList">
    <thead>
      <tr>
        <th>Время</th>
        <th>Сторона 1</th>
        <th>Условия</th>
        <th>Сторона 2</th>
        <th>Действие</th>
      </tr>
    </thead>
    <tbody>
      <% if visible_applications.empty? %>
        <tr>
          <td colspan="5" class="nl-arena-empty">Заявок не найдено</td>
        </tr>
      <% else %>
        <% visible_applications.each do |app| %>
          <% applicant_name = app.npc_application? ? app.npc_template.name : app.applicant.name %>
          <% applicant_level = app.npc_application? ? app.npc_template.level : app.applicant.level %>
          <% own_app = app.applicant == current_character %>
          <tr class="<%= 'nl-arena-row--own' if own_app %> <%= 'nl-arena-row--npc' if app.npc_application? %>" data-application-id="<%= app.id %>">
            <td><%= app.created_at.strftime("%H:%M:%S") %></td>
            <td>
              <b><%= applicant_name %>[<%= applicant_level %>]</b>
            </td>
            <td>
              <%= fight_kind_label(app.fight_kind) %>,
              <%= app.timeout_seconds / 60 %> мин,
              травма <%= app.trauma_percent %>%,
              ожидание <%= distance_of_time_in_words_to_now(app.expires_at) %>
            </td>
            <td>
              <b>нет соперников</b>
            </td>
            <td>
              <% if own_app %>
                <%= button_to "отозвать",
                    arena_room_arena_application_path(@room, app),
                    method: :delete,
                    class: "nl-arena-small-button" %>
              <% elsif app.acceptable_by?(current_character) %>
                <%= button_to "принять",
                    accept_arena_room_arena_application_path(@room, app),
                    method: :post,
                    class: "nl-arena-small-button",
                    data: {
                      action: "click->arena#acceptApplication",
                      application_id: app.id
                    } %>
              <% else %>
                <span class="nl-arena-muted">нельзя принять</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>

  <% if @active_matches.any? %>
    <div class="nl-arena-active-matches">
      <b>Текущие бои</b>
      <% @active_matches.each do |match| %>
        <div class="nl-arena-recent-row">
          <%= match.match_type.humanize %>:
          <%= match.arena_participations.map(&:participant_name).join(" против ") %>
          <%= link_to "смотреть", arena_match_path(match), class: "nl-arena-filter" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="arena-countdown" data-arena-target="countdown" style="display: none;">
    <div class="arena-countdown-title">Match Starting</div>
    <div class="arena-countdown-timer">--</div>
  </div>
</div>
