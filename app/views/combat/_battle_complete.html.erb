<%#
  Battle Complete Partial

  Displays victory/defeat screen with rewards and options.

  Required locals:
  - battle: Battle record
  - player_participant: BattleParticipant
  - won: Boolean - true if player won
%>

<div class="nl-battle-complete" id="combat-interface">
  <div class="nl-result-banner nl-result-banner--<%= won ? 'victory' : 'defeat' %>">
    <h1><%= won ? "Victory!" : "Defeat" %></h1>
    <p class="nl-result-subtitle">
      <% if won %>
        You have emerged victorious!
      <% else %>
        You have been defeated in combat.
      <% end %>
    </p>
  </div>

  <% if won %>
    <div class="nl-rewards-panel">
      <h3>Rewards</h3>
      <ul class="nl-rewards-list">
        <li>
          <span class="nl-reward-label">Experience:</span>
          <span class="nl-reward-value">+<%= calculate_xp_reward(battle, player_participant) %> XP</span>
        </li>
        <li>
          <span class="nl-reward-label">Gold:</span>
          <span class="nl-reward-value">+<%= calculate_gold_reward(battle, player_participant) %></span>
        </li>
        <% if battle.arena? %>
          <li>
            <span class="nl-reward-label">Arena Points:</span>
            <span class="nl-reward-value">+<%= calculate_arena_points(battle, won) %></span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="nl-battle-stats">
    <h3>Combat Statistics</h3>
    <div class="nl-stats-grid">
      <div class="nl-stat">
        <span class="nl-stat-label">Turns:</span>
        <span class="nl-stat-value"><%= battle.turn_number %></span>
      </div>
      <div class="nl-stat">
        <span class="nl-stat-label">Duration:</span>
        <span class="nl-stat-value"><%= format_battle_duration(battle) %></span>
      </div>
      <div class="nl-stat">
        <span class="nl-stat-label">Damage Dealt:</span>
        <span class="nl-stat-value"><%= total_damage_dealt(player_participant) %></span>
      </div>
      <div class="nl-stat">
        <span class="nl-stat-label">Hits Landed:</span>
        <span class="nl-stat-value"><%= player_participant.hits_landed || 0 %></span>
      </div>
    </div>
  </div>

  <div class="nl-battle-actions">
    <%= link_to "View Combat Log", combat_log_path(battle), class: "nl-btn nl-btn--secondary" %>
    <%= link_to "Return to World", root_path, class: "nl-btn nl-btn--primary" %>
    <% if battle.arena? %>
      <%= link_to "Back to Arena", arena_index_path, class: "nl-btn nl-btn--secondary" %>
    <% end %>
  </div>
</div>
