<%#
  Battle Defeat Partial

  Displays when player loses the battle.

  Required locals:
  - battle: Battle record
  - player_participant: BattleParticipant
%>

<div class="nl-battle-defeat" id="combat-interface">
  <div class="nl-result-banner nl-result-banner--defeat">
    <h1>Defeated</h1>
    <p class="nl-result-subtitle">You have fallen in combat.</p>
  </div>

  <div class="nl-defeat-info">
    <p>Your character is weakened and needs time to recover.</p>
    <p>HP will regenerate over time.</p>
  </div>

  <div class="nl-battle-stats">
    <h3>Combat Statistics</h3>
    <div class="nl-stats-grid">
      <div class="nl-stat">
        <span class="nl-stat-label">Turns Survived:</span>
        <span class="nl-stat-value"><%= battle.turn_number %></span>
      </div>
      <div class="nl-stat">
        <span class="nl-stat-label">Damage Dealt:</span>
        <span class="nl-stat-value">
          <%= player_participant.damage_dealt.values.sum rescue 0 %>
        </span>
      </div>
    </div>
  </div>

  <div class="nl-battle-actions">
    <%= link_to "View Combat Log", combat_log_path(battle), class: "nl-btn nl-btn--secondary" %>
    <%= link_to "Return to World", root_path, class: "nl-btn nl-btn--primary" %>
  </div>
</div>
