<div class="location-info-panel">
  <h3>Current Location</h3>

  <div class="location-description">
    <% if zone.city? %>
      <p>You are in <strong><%= zone.name %></strong>, a compact city node with
         source-backed hotspots.</p>
      <p class="location-hint">Use the city scene to enter documented buildings such as Arena or Лавка.</p>
    <% elsif zone.outdoor? %>
      <p>You are outside at <strong><%= zone.name %></strong>.</p>
      <p class="location-hint">⚠️ Wild creatures may attack travelers here.</p>
    <% else %>
      <p>You are at <strong><%= zone.name %></strong> [<%= position.x %>, <%= position.y %>].</p>
    <% end %>
  </div>

  <% if tile.respond_to?(:metadata) && tile.metadata.present? %>
    <div class="tile-features">
      <% if tile.metadata["npc"] %>
        <div class="feature-item">
          <span class="feature-icon">👤</span>
          <span><%= tile.metadata["npc"] %></span>
        </div>
      <% end %>
      <% if tile.metadata["shop"] %>
        <div class="feature-item">
          <span class="feature-icon">🏪</span>
          <span><%= tile.metadata["shop"] %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
