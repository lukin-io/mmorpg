<div class="players-panel">
  <h3>Players on this tile</h3>
  <% if players.any? %>
    <ul class="players-list">
      <% players.each do |pos| %>
        <li class="player-item">
          <span class="player-avatar">»</span>
          <div class="player-info">
            <span class="player-name"><%= pos.character.name %></span>
            <span class="player-level">[<%= pos.character.level %>]</span>
          </div>
          <div class="player-actions">
            <%= link_to "Info", player_path(name: pos.character.name), title: "Character" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted text-sm">No players nearby.</p>
  <% end %>
</div>
