<% inventory ||= @inventory %>

<div class="nl-inventory-list">
  <% items.each do |item| %>
    <div class="inventory-slot filled nl-inventory-item"
         data-item-id="<%= item.id %>"
         data-action="click->inventory#selectItem contextmenu->inventory#showContextMenu">
      <div class="nl-inventory-item-icon item-rarity--<%= item.item_template.rarity %>">
        <span><%= item_slot_icon(item.item_template) %></span>
        <% if item.quantity > 1 %>
          <strong><%= item.quantity %></strong>
        <% end %>
        <div class="nl-durability-bar">
          <span style="width: <%= inventory_item_durability_percent(item) %>%"></span>
        </div>
      </div>

      <div class="nl-inventory-item-body">
        <div class="nl-inventory-item-actions">
          <% if item.item_template.equippable? && !item.equipped? %>
            <%= button_to "Equip", equip_inventory_path(item_id: item.id), method: :post, class: "invbut", data: {turbo: true} %>
          <% end %>
          <% if item.item_template.consumable? %>
            <%= button_to "Use", use_inventory_path(item_id: item.id), method: :post, class: "invbut", data: {turbo: true} %>
          <% end %>
          <span class="invbut invbut--disabled">Transfer</span>
          <span class="invbut invbut--disabled">Gift</span>
          <span class="invbut invbut--disabled">Sell</span>
          <%= button_to "Delete",
            inventory_item_path(item),
            method: :delete,
            class: "invbut invbut--danger",
            form: {data: {turbo_confirm: "Delete #{item.item_template.name}?"}} %>
        </div>

        <div class="nl-inventory-item-details">
          <section>
            <h3>Properties</h3>
            <table class="nl-profile-table">
              <tr>
                <th>Name</th>
                <td><%= item.item_template.name %></td>
              </tr>
              <% inventory_item_properties(item).each do |label, value| %>
                <tr>
                  <th><%= label %></th>
                  <td><%= value %></td>
                </tr>
              <% end %>
            </table>
          </section>

          <section>
            <h3>Requirements</h3>
            <table class="nl-profile-table">
              <% inventory_item_requirements(item).each do |label, value| %>
                <tr>
                  <th><%= label %></th>
                  <td><%= value %></td>
                </tr>
              <% end %>
            </table>
          </section>
        </div>
      </div>
    </div>
  <% end %>

  <% if items.empty? %>
    <p class="nl-profile-empty">No items in this category.</p>
  <% end %>

  <% [inventory.max_slots - inventory.inventory_items.count, 0].max.times do |i| %>
    <div class="inventory-slot empty nl-inventory-empty-slot" data-slot-index="<%= inventory.inventory_items.count + i %>">
      empty
    </div>
  <% end %>
</div>

<div class="item-context-menu" data-inventory-target="contextMenu" style="display: none;">
  <ul>
    <li>
      <%= form_with url: equip_inventory_path, method: :post, data: {turbo_stream: true}, class: "context-menu-form" do %>
        <%= hidden_field_tag :item_id, "", data: {inventory_target: "contextItemId"} %>
        <button type="submit" class="context-menu-btn" data-action="click->inventory#hideContextMenu">Equip</button>
      <% end %>
    </li>
    <li>
      <%= form_with url: use_inventory_path, method: :post, data: {turbo_stream: true}, class: "context-menu-form" do %>
        <%= hidden_field_tag :item_id, "", data: {inventory_target: "contextItemId"} %>
        <button type="submit" class="context-menu-btn" data-action="click->inventory#hideContextMenu">Use</button>
      <% end %>
    </li>
  </ul>
</div>
