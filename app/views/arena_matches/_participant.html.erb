<%#
  Arena match participant with HP/MP bars
  Supports both characters and NPCs

  Required locals:
  - participation: ArenaParticipation record
%>
<% p_data = participant_data(participation) %>

<div class="arena-participant <%= 'arena-participant--dead' if p_data.current_hp <= 0 %> <%= 'arena-participant--npc' if p_data.is_npc %>"
     data-character-id="<%= p_data.id %>"
     data-npc="<%= p_data.is_npc %>">
  <div class="arena-participant-avatar">
    <%= participation_avatar_tag(participation, size: :medium) %>
  </div>
  <div class="arena-participant-info">
    <span class="arena-participant-name"><%= p_data.name %></span>
    <span class="arena-participant-level">[<%= p_data.level %>]</span>

    <div class="arena-bars">
      <div class="arena-hp-bar">
        <div class="arena-hp-fill" style="width: <%= p_data.hp_percent %>%"></div>
        <span class="arena-hp-text"><%= p_data.current_hp %>/<%= p_data.max_hp %></span>
      </div>
      <% unless p_data.is_npc %>
        <div class="arena-mp-bar">
          <div class="arena-mp-fill" style="width: <%= p_data.mp_percent %>%"></div>
        </div>
      <% end %>
    </div>
  </div>

  <% if participation.result.present? && participation.result != "pending" %>
    <span class="arena-result-badge arena-result-badge--<%= participation.result %>">
      <%= participation.result.humanize %>
    </span>
  <% end %>
</div>
