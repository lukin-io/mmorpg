<% content_for :title, "Arena Match ##{@arena_match.id}" %>

<%
  # Get participants by team (a/alpha vs b/beta)
  player_a = @participations.find { |p| p.team == "a" || p.team == "alpha" }
  player_b = @participations.find { |p| p.team == "b" || p.team == "beta" }
  user_team = current_user_team
  combat_config = Game::Combat::ActionCatalog.config
  attack_options = combat_config["attack_types"] || {}
  block_options = combat_config["block_types"] || {}
%>

<div class="arena-match-page"
     data-controller="arena-match"
     data-arena-match-match-id-value="<%= @arena_match.id %>"
     data-arena-match-spectating-value="<%= !current_user_participating? %>"
     data-arena-match-spectator-code-value="<%= @arena_match.spectator_code if !current_user_participating? %>">

  <div class="page-header page-header--compact">
    <%= link_to "← Back to Arena", arena_index_path, class: "btn-secondary btn-sm" %>
    <h1>
      <%= @arena_match.match_type.humanize %>
      <span class="badge badge--<%= @arena_match.status %>"><%= @arena_match.status.humanize %></span>
    </h1>
  </div>

  <%# Main combat layout: Player | Actions+Log | Opponent %>
  <div class="arena-pvp-layout">
    <%# Left: Player A %>
    <div class="arena-fighter arena-fighter--left" data-arena-match-target="fighterA">
      <% if player_a %>
        <%= render "arena_matches/fighter_card",
            participation: player_a,
            show_stats: (user_team == "b" || user_team == "beta"),
            position: :left %>
      <% else %>
        <div class="arena-fighter-empty">Waiting for opponent...</div>
      <% end %>
    </div>

    <%# Center: VS + Actions + Combat Log %>
    <div class="arena-center">
      <div class="arena-vs-badge">⚔️ VS</div>

      <%# Turn timeout display %>
      <% if @arena_match.live? && @arena_match.current_turn_started_at %>
        <div class="arena-timeout-bar">
          <%= turn_timeout_display(@arena_match) %>
        </div>
      <% end %>

      <%# Combat action buttons (only for participants in live match) %>
      <% if @arena_match.live? && current_user_participating? %>
        <div class="arena-action-panel" data-arena-match-target="actionButtons">
          <%# AP Bar %>
          <div class="arena-ap-bar" data-arena-match-target="apBar">
            <span class="ap-label">AP:</span>
            <div class="ap-bar-container">
              <div class="ap-bar-fill" style="width: 100%"></div>
            </div>
            <span class="ap-value" data-arena-match-target="apValue">80/80</span>
          </div>

          <div class="arena-turn-composer">
            <div class="arena-turn-field arena-attack-type-select">
              <label for="arena-attack-type">Attack</label>
              <select id="arena-attack-type"
                      data-arena-match-target="attackTypeSelect"
                      data-action="change->arena-match#updateTurnCost"
                      class="form-select form-select--compact">
                <% attack_options.each do |key, config| %>
                  <option value="<%= key %>" data-ap-cost="<%= config['action_cost'] %>">
                    <%= config["name"] || key.titleize %> (<%= config["action_cost"] %>)
                  </option>
                <% end %>
              </select>
            </div>

            <div class="arena-turn-field arena-target-select">
              <label for="arena-body-part">Target</label>
              <select id="arena-body-part"
                      data-arena-match-target="bodyPartSelect"
                      class="form-select form-select--compact">
                <option value="head">Head</option>
                <option value="torso" selected>Torso</option>
                <option value="stomach">Stomach</option>
                <option value="legs">Legs</option>
              </select>
            </div>

            <div class="arena-turn-field arena-block-select">
              <label for="arena-block">Block</label>
              <select id="arena-block"
                      data-arena-match-target="blockSelect"
                      data-action="change->arena-match#updateTurnCost"
                      class="form-select form-select--compact">
                <option value="none" data-ap-cost="0">No block (0)</option>
                <% block_options.each do |key, config| %>
                  <% body_parts = config["body_parts"] || [config["body_part"]].compact %>
                  <% next if body_parts.length > 2 %>
                  <% next if config["action_cost"].to_i > Game::Combat::ActionCatalog::DEFAULT_AP_PER_TURN %>
                  <option value="<%= key %>"
                          data-ap-cost="<%= config['action_cost'] %>"
                          data-body-parts="<%= body_parts.join(',') %>"
                          <%= "selected" if key == "torso_block" %>>
                    <%= config["name"] || key.titleize %> (<%= config["action_cost"] %>)
                  </option>
                <% end %>
              </select>
            </div>

            <div class="arena-turn-submit">
              <span class="arena-turn-cost">
                Cost <span data-arena-match-target="turnCostValue">75/80</span>
              </span>
              <button class="btn-attack btn-attack--submit"
                      data-action="click->arena-match#submitTurn"
                      data-ap-cost="75">
                Submit Turn
              </button>
            </div>
          </div>
        </div>
      <% end %>

      <%# Combat Log %>
      <div class="arena-combat-log" data-arena-match-target="combatLog">
        <div class="combat-log-entry combat-log--system">
          <span class="combat-time"><%= @arena_match.created_at.strftime("%H:%M:%S") %></span>
          Match created
        </div>
        <% if @arena_match.started_at %>
          <div class="combat-log-entry combat-log--system combat-log--highlight">
            <span class="combat-time"><%= @arena_match.started_at.strftime("%H:%M:%S") %></span>
            ⚔️ FIGHT!
          </div>
        <% end %>
        <% (@arena_match.metadata["combat_log"] || []).each do |entry| %>
          <div class="combat-log-entry combat-log--<%= entry['type'] || 'action' %>">
            <span class="combat-time"><%= entry['timestamp'] %></span>
            <%= entry['description'] %>
          </div>
        <% end %>
        <% if @arena_match.completed? %>
          <div class="combat-log-entry combat-log--<%= @arena_match.winning_team ? 'victory' : 'draw' %>">
            <span class="combat-time"><%= @arena_match.ended_at&.strftime("%H:%M:%S") %></span>
            🏆 <%= @arena_match.winning_team ? "Winner: #{winner_name(@arena_match)}" : "Draw!" %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Right: Player B %>
    <div class="arena-fighter arena-fighter--right" data-arena-match-target="fighterB">
      <% if player_b %>
        <%= render "arena_matches/fighter_card",
            participation: player_b,
            show_stats: (user_team == "a" || user_team == "alpha"),
            position: :right %>
      <% else %>
        <div class="arena-fighter-empty">Waiting for opponent...</div>
      <% end %>
    </div>
  </div>

  <%# Match info bar (compact, below main layout) %>
  <div class="arena-match-bar">
    <span class="match-bar-item">
      <strong><%= @arena_match.match_type.humanize %></strong>
      <% if @arena_match.arena_room %>
        in <%= @arena_match.arena_room.name %>
      <% end %>
    </span>
    <% if @arena_match.started_at %>
      <span class="match-bar-item">Started: <%= l(@arena_match.started_at, format: :short) %></span>
    <% end %>
    <% if @arena_match.duration && @arena_match.duration < 3600 %>
      <span class="match-bar-item">Duration: <%= format_duration(@arena_match.duration) %></span>
    <% end %>
    <% if @arena_match.turn_timeout_seconds %>
      <span class="match-bar-item">Timeout: <%= @arena_match.turn_timeout_seconds / 60 %>m</span>
    <% end %>
    <% if @arena_match.spectator_code && !current_user_participating? %>
      <span class="match-bar-item text-muted">Spectating</span>
    <% end %>
  </div>

  <%# Countdown timer overlay %>
  <div class="arena-countdown-overlay" data-arena-match-target="timer" style="display: none;">
    <div class="arena-countdown-content">
      <div class="arena-countdown-title">Match Starting</div>
      <div class="arena-countdown-timer">--</div>
    </div>
  </div>

  <%# Result overlay %>
  <% if @arena_match.completed? %>
    <div class="arena-result-overlay arena-result--<%= current_user_won? ? 'victory' : (current_user_participating? ? 'defeat' : 'ended') %>"
         data-arena-match-target="resultOverlay">
      <div class="arena-result-content">
        <h1 class="arena-result-title">
          <%= current_user_won? ? "VICTORY!" : (current_user_participating? ? "DEFEAT" : "MATCH ENDED") %>
        </h1>
        <div class="arena-result-details">
          <% if @arena_match.winning_team %>
            <p>Winner: <strong><%= winner_name(@arena_match) %></strong></p>
          <% else %>
            <p>Match ended in a draw</p>
          <% end %>
          <p class="text-muted">Duration: <%= format_duration(@arena_match.duration || 0) %></p>
        </div>
        <%= link_to "Return to Arena", arena_index_path, class: "btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
