<% content_for :title, "#{@character.name} - Character" %>

<%= turbo_frame_tag "main_content" do %>
  <section class="nl-player-profile">
    <%= render "shared/player_context_buttons",
      character: @character,
      viewer_character: @viewer_character,
      current_section: :profile %>

    <div class="nl-player-profile-head">
      <div class="nl-player-profile-identity">
        <div>
          <h1><%= @character.name %> [<%= @character.level %>]</h1>
          <div class="nl-profile-subline">
            <span>Player</span>
            <span><%= profile_location(@character) %></span>
            <span>Created <%= l(@character.created_at.to_date, format: :default) %></span>
          </div>
        </div>
      </div>
      <%= render "shared/nl_vitals_bar", character: @character %>
    </div>

    <div class="nl-player-profile-grid">
      <aside class="nl-player-profile-left">
        <%= render "shared/player_equipment_summary", character: @character, equipment: @equipment %>
      </aside>

      <main class="nl-player-profile-main">
        <div class="nl-profile-panel">
          <h2>Progression</h2>
          <table class="nl-profile-table nl-profile-table--wide">
            <tr>
              <th>Combat experience</th>
              <td><%= number_with_delimiter(@character.experience) %></td>
            </tr>
            <tr>
              <th>To next level</th>
              <td><%= number_with_delimiter(@character.experience_to_next_level) %></td>
            </tr>
            <tr>
              <th>Alignment</th>
              <td><%= @character.alignment_label %></td>
            </tr>
            <tr>
              <th>Valor</th>
              <td><%= number_with_delimiter(@character.metadata.to_h.fetch("valor", 0)) %></td>
            </tr>
            <tr>
              <th>Fatigue</th>
              <td><%= profile_fatigue(@character) %>%</td>
            </tr>
            <tr>
              <th>AP per attack</th>
              <td><%= profile_attack_cost %></td>
            </tr>
          </table>
        </div>

        <div class="nl-profile-panel">
          <h2>Fight Record</h2>
          <table class="nl-profile-table nl-profile-table--wide">
            <tr>
              <th>Player wins</th>
              <td><%= @character.metadata.to_h.fetch("player_wins", 0) %></td>
              <th>Player losses</th>
              <td><%= @character.metadata.to_h.fetch("player_losses", 0) %></td>
            </tr>
            <tr>
              <th>NPC wins</th>
              <td><%= @character.metadata.to_h.fetch("npc_wins", 0) %></td>
              <th>NPC losses</th>
              <td><%= @character.metadata.to_h.fetch("npc_losses", 0) %></td>
            </tr>
          </table>
        </div>

        <div class="nl-profile-panel">
          <h2>Skills</h2>
          <div class="nl-profile-skill-list">
            <% Game::Skills::PassiveSkillRegistry.all.first(12).each do |key, definition| %>
              <div class="nl-profile-skill-row">
                <span><%= definition[:name] %></span>
                <strong>[<%= profile_skill_level(@character, key) %>/100]</strong>
              </div>
            <% end %>
          </div>
        </div>
      </main>
    </div>
  </section>
<% end %>
