<% character ||= nil %>
<% equipment ||= {} %>
<% left_slots = [
  ["head", "Helmet"],
  ["amulet", "Necklace"],
  ["main_hand", "Weapon"],
  ["belt", "Belt"],
  ["legs", "Pants"],
  ["feet", "Boots"]
] %>
<% right_slots = [
  ["off_hand", "Weapon/Shield"],
  ["chest", "Armor"],
  ["hands", "Gloves"],
  ["bracers", "Bracers"],
  ["pocket", "Pocket"],
  ["relic", "Relic"]
] %>
<% lower_slots = [
  ["ring_1", "Ring"],
  ["ring_2", "Ring"],
  ["ring_3", "Ring"],
  ["ring_4", "Ring"],
  ["belt_1", "Belt Item"],
  ["belt_2", "Belt Item"],
  ["belt_3", "Belt Item"],
  ["pocket_1", "Pocket Item"]
] %>

<div class="nl-equipment-summary">
  <div class="nl-equipment-paperdoll">
    <div class="nl-equipment-side nl-equipment-side--left">
      <% left_slots.each do |slot_key, label| %>
        <% item = equipment[slot_key] || equipment[slot_key.to_sym] %>
        <div class="nl-profile-slot <%= 'nl-profile-slot--filled' if item %>">
          <span class="nl-profile-slot-label"><%= label %></span>
          <span class="nl-profile-slot-value"><%= item&.item_template&.name || "empty" %></span>
        </div>
      <% end %>
    </div>

    <div class="nl-equipment-portrait">
      <% if character %>
        <%= image_tag character.avatar_image_path, alt: character.name, class: "nl-equipment-character-image", loading: "lazy" %>
      <% end %>
      <div class="nl-equipment-avatar-caption">
        <strong><%= character&.name || "Unknown" %></strong>
        <span>Level <%= character&.level || "-" %></span>
      </div>
    </div>

    <div class="nl-equipment-side nl-equipment-side--right">
      <% right_slots.each do |slot_key, label| %>
        <% item = equipment[slot_key] || equipment[slot_key.to_sym] %>
        <div class="nl-profile-slot <%= 'nl-profile-slot--filled' if item %>">
          <span class="nl-profile-slot-label"><%= label %></span>
          <span class="nl-profile-slot-value"><%= item&.item_template&.name || "empty" %></span>
        </div>
      <% end %>
    </div>

    <div class="nl-equipment-lower-slots">
      <% lower_slots.each do |slot_key, label| %>
        <% item = equipment[slot_key] || equipment[slot_key.to_sym] %>
        <div class="nl-profile-slot nl-profile-slot--compact <%= 'nl-profile-slot--filled' if item %>">
          <span class="nl-profile-slot-label"><%= label %></span>
          <span class="nl-profile-slot-value"><%= item&.item_template&.name || "empty" %></span>
        </div>
      <% end %>
    </div>
  </div>
  <div class="nl-equipment-location">
    <span>Location</span>
    <strong><%= profile_location(character) %></strong>
  </div>
  <% if equipment.empty? %>
    <div class="nl-profile-empty">No equipped items.</div>
  <% else %>
    <div class="nl-equipped-items-list">
      <% equipment.values.each do |item| %>
        <span><%= item.item_template&.name %></span>
      <% end %>
    </div>
  <% end %>
</div>
