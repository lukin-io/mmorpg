<div class="nl-allocation-panel nl-perk-allocation">
  <div class="nl-allocation-points">
    <span class="nl-allocation-points-label">Available Perks:</span>
    <span class="nl-allocation-points-value"><%= @character.perk_points_available %></span>
  </div>

  <% @perk_categories.each do |category_key, category_info| %>
    <% perks = @perks_by_category.fetch(category_key, []) %>
    <% next if perks.empty? %>

    <section class="nl-perk-category">
      <h2><%= category_info[:name] %></h2>
      <p><%= category_info[:description] %></p>

      <div class="nl-perk-grid">
        <% perks.each do |perk| %>
          <% key = perk[:key].to_s %>
          <% selected = @selected_perks.include?(key) %>
          <% excluded = @excluded_perks.include?(key) %>
          <% selectable = !selected && !excluded && @character.level >= perk[:level_required] && @character.perk_points_available.positive? %>

          <div class="nl-perk-row <%= 'nl-perk-row--selected' if selected %> <%= 'nl-perk-row--locked' unless selectable || selected %>">
            <div class="nl-perk-main">
              <strong><%= perk[:name] %></strong>
              <span><%= selected ? "yes" : "no" %></span>
            </div>
            <p><%= perk[:description] %></p>
            <div class="nl-perk-meta">
              <span>Level <%= perk[:level_required] %></span>
              <% if excluded %>
                <span>Excluded by selected perk</span>
              <% elsif @character.level < perk[:level_required] %>
                <span>Requires level <%= perk[:level_required] %></span>
              <% elsif @character.perk_points_available <= 0 && !selected %>
                <span>No perk points</span>
              <% elsif perk[:excludes].present? %>
                <span>Excludes <%= perk[:excludes].map { |excluded_key| excluded_key.to_s.humanize }.join(", ") %></span>
              <% end %>
            </div>

            <% if selectable %>
              <%= form_with url: perks_character_path(@character), method: :patch, class: "nl-perk-form" do %>
                <%= hidden_field_tag :perk_key, key %>
                <%= submit_tag "Select", class: "nl-btn nl-btn--primary" %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
