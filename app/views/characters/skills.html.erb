<% content_for :title, "Skills - #{@character.name}" %>

<%= turbo_frame_tag "main_content" do %>
  <div class="nl-allocation-page nl-player-subpage">
    <%= render "shared/player_context_buttons",
      character: @character,
      viewer_character: current_character,
      current_section: :skills %>

    <div class="nl-allocation-header">
      <h1 class="nl-allocation-title">Skills</h1>
      <p class="nl-allocation-subtitle"><%= @character.name %> [<%= @character.level %>] training 0-100</p>
    </div>

    <turbo-frame id="skill-allocation">
      <%= render "characters/skill_allocation" %>
    </turbo-frame>

    <div class="nl-allocation-footer">
      <%= link_to "Map", world_path, class: "nl-btn nl-btn--secondary" %>
      <%= link_to "Character", player_path(name: @character.name), class: "nl-btn nl-btn--secondary" %>
      <%= link_to "Stats", stats_character_path(@character), class: "nl-btn nl-btn--secondary" %>
    </div>
  </div>
<% end %>
