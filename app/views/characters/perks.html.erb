<% content_for :title, "Perks - #{@character.name}" %>

<%= turbo_frame_tag "main_content" do %>
  <div class="nl-allocation-page nl-player-subpage">
    <%= render "shared/player_context_buttons",
      character: @character,
      viewer_character: current_character,
      current_section: :perks %>

    <div class="nl-allocation-header">
      <h1 class="nl-allocation-title">Perks</h1>
      <p class="nl-allocation-subtitle"><%= @character.name %> [<%= @character.level %>] yes/no unlocks with exclusions</p>
    </div>

    <%= render "characters/perk_allocation" %>

    <div class="nl-allocation-footer">
      <%= link_to "Character", profile_path(profile_name: @character.name), class: "nl-btn nl-btn--secondary" %>
      <%= link_to "Stats", stats_character_path(@character), class: "nl-btn nl-btn--secondary" %>
      <%= link_to "Abilities", skills_character_path(@character), class: "nl-btn nl-btn--secondary" %>
    </div>
  </div>
<% end %>
