<%#
  Skill Allocation Partial - Tiered progression system
  Uses skill_allocation_controller.js for client-side updates

  Features:
  - Dual skill point pools (Combat and Peace)
  - Tiered progression (more points at low levels, fewer at high)
  - Skills grouped by category
%>
<%
  # Build data structures for the Stimulus controller
  skills_json = @skills_data.transform_values { |v| v[:level] }.to_json
  rates_json = @skills_data.transform_values { |v| v[:progression_rate] }.to_json
  pools_json = @skills_data.transform_values { |v| v[:pool].to_s }.to_json
%>
<div class="nl-allocation-panel"
     data-controller="skill-allocation"
     data-skill-allocation-combat-free-value="<%= @combat_skill_points %>"
     data-skill-allocation-peace-free-value="<%= @peace_skill_points %>"
     data-skill-allocation-skills-value="<%= skills_json %>"
     data-skill-allocation-rates-value="<%= rates_json %>"
     data-skill-allocation-pools-value="<%= pools_json %>"
     data-skill-allocation-spends-value="{}">

  <%# Dual Skill Point Pools %>
  <div class="nl-allocation-pools">
    <div class="nl-allocation-pool nl-allocation-pool--combat">
      <span class="nl-allocation-pool-icon">⚔️</span>
      <span class="nl-allocation-pool-label">Боевые очки:</span>
      <span class="nl-allocation-pool-value" data-skill-allocation-target="combatPoints">
        <%= @combat_skill_points %>
      </span>
    </div>
    <div class="nl-allocation-pool nl-allocation-pool--peace">
      <span class="nl-allocation-pool-icon">🕊️</span>
      <span class="nl-allocation-pool-label">Мирные очки:</span>
      <span class="nl-allocation-pool-value" data-skill-allocation-target="peacePoints">
        <%= @peace_skill_points %>
      </span>
    </div>
  </div>

  <%= form_with url: skills_character_path(@character), method: :patch, class: "nl-allocation-form", data: { turbo_frame: "skill-allocation" } do |f| %>
    <% Game::Skills::PassiveSkillRegistry.categories.each do |category_key, category_info| %>
      <% category_skills = @skill_definitions.select { |_, def_| def_[:category] == category_key } %>
      <% next if category_skills.empty? %>

      <div class="nl-skill-category-section">
        <h3 class="nl-skill-category-header nl-skill-category-header--<%= category_key %>">
          <span class="nl-skill-category-icon">
            <% case category_key
               when :combat then %><%= "⚔️" %>
            <% when :magic then %><%= "✨" %>
            <% when :resistance then %><%= "🛡️" %>
            <% when :peace_world then %><%= "🕊️" %>
            <% end %>
          </span>
          <%= category_info[:name] %>
        </h3>

        <div class="nl-skills-grid">
          <% category_skills.each do |skill_key, definition| %>
            <% skill_info = @skills_data[skill_key] %>
            <div class="nl-skill-row">
              <div class="nl-skill-info">
                <span class="nl-skill-name"><%= definition[:name] %></span>
                <p class="nl-skill-description"><%= definition[:description] %></p>
              </div>

              <div class="nl-skill-controls">
                <button type="button"
                        class="nl-stat-btn nl-stat-btn--minus"
                        data-action="click->skill-allocation#removeSkill"
                        data-skill-allocation-skill-param="<%= skill_key %>"
                        data-skill-allocation-pool-param="<%= definition[:pool] %>"
                        data-skill-allocation-rate-param="<%= definition[:progression_rate] %>">
                  −
                </button>

                <span class="nl-skill-value"
                      data-skill-allocation-target="skillValue"
                      data-skill="<%= skill_key %>">
                  [<%= skill_info[:level].to_s.rjust(3, "0") %>/100]
                </span>

                <button type="button"
                        class="nl-stat-btn nl-stat-btn--plus"
                        data-action="click->skill-allocation#addSkill"
                        data-skill-allocation-skill-param="<%= skill_key %>"
                        data-skill-allocation-pool-param="<%= definition[:pool] %>"
                        data-skill-allocation-rate-param="<%= definition[:progression_rate] %>"
                        <%= "disabled" if skill_info[:at_max] %>>
                  +
                </button>

                <%= hidden_field_tag "allocated_skills[#{skill_key}]", 0,
                                     data: { skill_allocation_target: "skillInput", skill: skill_key } %>
              </div>

              <div class="nl-skill-meta">
                <div class="nl-skill-gain"
                     data-skill-allocation-target="skillGain"
                     data-skill="<%= skill_key %>">
                  <% if skill_info[:at_max] %>
                    MAX
                  <% else %>
                    +<%= skill_info[:points_per_spend] %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="nl-allocation-actions">
      <button type="button"
              class="nl-btn nl-btn--secondary"
              data-action="click->skill-allocation#reset">
        Сброс
      </button>
      <button type="submit"
              class="nl-btn nl-btn--primary nl-btn--disabled"
              data-skill-allocation-target="saveButton"
              disabled>
        Сохранить
      </button>
    </div>
  <% end %>

</div>
