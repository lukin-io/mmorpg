<% content_for :title, "Stats - #{@character.name}" %>

<%= turbo_frame_tag "main_content" do %>
  <div class="nl-allocation-page nl-player-subpage">
    <%= render "shared/player_context_buttons",
      character: @character,
      viewer_character: current_character,
      current_section: :stats %>

    <div class="nl-allocation-header">
      <h1 class="nl-allocation-title">Character Stats</h1>
      <p class="nl-allocation-subtitle"><%= @character.name %> [<%= @character.level %>] primary stat allocation</p>
    </div>

    <turbo-frame id="stat-allocation">
      <%= render "characters/stat_allocation" %>
    </turbo-frame>

    <div class="nl-allocation-footer">
      <%= link_to "Character", player_path(name: @character.name), class: "nl-btn nl-btn--secondary" %>
      <%= link_to "Skills", skills_character_path(@character), class: "nl-btn nl-btn--secondary" %>
    </div>
  </div>
<% end %>
